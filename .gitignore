# ============================
# Mya Assistant - .gitignore
# React Native + Electron + Supabase + pnpm Monorepo
# ============================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Build outputs ---
dist/
build/
out/
*.tsbuildinfo

# --- React Native ---
# Android
packages/mobile/android/app/build/
packages/mobile/android/.gradle/
packages/mobile/android/build/
packages/mobile/android/local.properties
*.apk
*.aab
*.keystore
!debug.keystore

# iOS
packages/mobile/ios/Pods/
packages/mobile/ios/build/
*.xcworkspace
!*.xcworkspace/contents.xcworkspacedata
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
*.xcuserstate
xcuserdata/

# Metro bundler
.metro-health-check*

# --- Electron ---
packages/desktop/dist/
packages/desktop/out/

# --- Environment & secrets ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Supabase secrets (NEVER commit)
supabase/.env

# --- IDE & Editor ---
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- OS generated ---
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Testing ---
coverage/
.nyc_output/

# --- Misc ---
*.tgz
.cache/
.turbo/
.parcel-cache/

# --- Temporary files ---
tmp/
temp/
