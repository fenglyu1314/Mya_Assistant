{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./out/preload",
    "rootDir": "./src/preload",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["node"]
  },
  "include": ["src/preload/**/*.ts", "src/preload/**/*.d.ts"],
  "exclude": ["node_modules", "out"]
}
