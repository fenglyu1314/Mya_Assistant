{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["./src/renderer/*"],
      "@mya/shared": ["../shared/src"],
      "@mya/shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/renderer/**/*.d.ts",
    "src/preload/index.d.ts",
    "../shared/src/**/*.ts"
  ],
  "exclude": ["node_modules", "out"]
}
